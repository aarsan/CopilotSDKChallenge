{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "connectionName": {
      "type": "string",
      "defaultValue": "dev-infraforge-conn-eastus2-001",
      "metadata": {
        "description": "Name of the network connection"
      }
    },
    "environment": {
      "type": "string",
      "defaultValue": "dev",
      "allowedValues": ["prod", "staging", "dev", "test", "sandbox"],
      "metadata": {
        "description": "Environment type"
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "allowedValues": ["eastus2", "westus2", "westeurope", "northeurope"],
      "metadata": {
        "description": "Location for the connection"
      }
    },
    "virtualNetworkGateway1Id": {
      "type": "string",
      "defaultValue": "/subscriptions/00000000-0000-0000-0000-000000000000/resourceGroups/default-rg/providers/Microsoft.Network/virtualNetworkGateways/default-vgw",
      "metadata": {
        "description": "Resource ID of the first virtual network gateway"
      }
    },
    "connectionType": {
      "type": "string",
      "defaultValue": "IPsec",
      "allowedValues": ["IPsec", "ExpressRoute", "Vnet2Vnet"],
      "metadata": {
        "description": "Type of connection"
      }
    },
    "sharedKey": {
      "type": "secureString",
      "defaultValue": "DefaultSharedKey123!",
      "metadata": {
        "description": "Shared key for IPsec authentication"
      }
    },
    "owner": {
      "type": "string",
      "defaultValue": "admin@infraforge.com",
      "metadata": {
        "description": "Owner email address"
      }
    },
    "costCenter": {
      "type": "string",
      "defaultValue": "CC-12345",
      "metadata": {
        "description": "Cost center code"
      }
    },
    "project": {
      "type": "string",
      "defaultValue": "infraforge-network",
      "metadata": {
        "description": "Project name"
      }
    },
    "dataClassification": {
      "type": "string",
      "defaultValue": "internal",
      "metadata": {
        "description": "Data classification level"
      }
    },
    "team": {
      "type": "string",
      "defaultValue": "platform-team",
      "metadata": {
        "description": "Team responsible for the resource"
      }
    },
    "supportContact": {
      "type": "string",
      "defaultValue": "support@infraforge.com",
      "metadata": {
        "description": "Support contact email"
      }
    },
    "expiryDate": {
      "type": "string",
      "defaultValue": "2025-12-31",
      "metadata": {
        "description": "Resource expiry date"
      }
    },
    "localNetworkGateway2Id": {
      "type": "string",
      "defaultValue": "/subscriptions/00000000-0000-0000-0000-000000000000/resourceGroups/default-rg/providers/Microsoft.Network/localNetworkGateways/default-lgw",
      "metadata": {
        "description": "Resource ID of the local network gateway (for IPsec connections)"
      }
    }
  },
  "variables": {
    "createdDate": "[utcNow('yyyy-MM-dd')]"
  },
  "resources": [
    {
      "type": "Microsoft.Network/connections",
      "apiVersion": "2023-11-01",
      "name": "[parameters('connectionName')]",
      "location": "[parameters('location')]",
      "tags": {
        "environment": "[parameters('environment')]",
        "owner": "[parameters('owner')]",
        "costCenter": "[parameters('costCenter')]",
        "project": "[parameters('project')]",
        "dataClassification": "[parameters('dataClassification')]",
        "createdBy": "infraforge",
        "createdDate": "[variables('createdDate')]",
        "team": "[parameters('team')]",
        "expiryDate": "[parameters('expiryDate')]",
        "supportContact": "[parameters('supportContact')]"
      },
      "properties": {
        "connectionType": "[parameters('connectionType')]",
        "virtualNetworkGateway1": {
          "id": "[parameters('virtualNetworkGateway1Id')]"
        },
        "localNetworkGateway2": {
          "id": "[parameters('localNetworkGateway2Id')]"
        },
        "sharedKey": "[parameters('sharedKey')]",
        "connectionProtocol": "IKEv2",
        "enableBgp": false,
        "dpdTimeoutSeconds": 45,
        "trafficSelectorPolicies": [],
        "ipsecPolicies": [
          {
            "saLifeTimeSeconds": 3600,
            "saDataSizeKilobytes": 102400000,
            "ipsecEncryption": "AES256",
            "ipsecIntegrity": "SHA256",
            "ikeEncryption": "AES256",
            "ikeIntegrity": "SHA256",
            "dhGroup": "DHGroup24",
            "pfsGroup": "PFS24"
          }
        ]
      }
    }
  ],
  "outputs": {
    "connectionId": {
      "type": "string",
      "value": "[resourceId('Microsoft.Network/connections', parameters('connectionName'))]"
    },
    "connectionName": {
      "type": "string",
      "value": "[parameters('connectionName')]"
    },
    "provisioningState": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Network/connections', parameters('connectionName'))).provisioningState]"
    }
  }
}